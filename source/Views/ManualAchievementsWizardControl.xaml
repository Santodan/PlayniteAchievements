<UserControl x:Class="PlayniteAchievements.Views.ManualAchievementsWizardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:PlayniteAchievements.Views"
             xmlns:vm="clr-namespace:PlayniteAchievements.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance vm:ManualAchievementsWizardViewModel}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Stage Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Foreground="{DynamicResource TextBrush}" Opacity="0.75">
                <Run Text="{DynamicResource LOCPlayAch_ManualAchievements_Wizard_GameLabel}"/>
                <Run Text="{Binding PlayniteGameName, Mode=OneTime}" FontWeight="Bold"/>
            </TextBlock>
        </StackPanel>

        <!-- Stage Content -->
        <Grid Grid.Row="1">
            <!-- Stage 1: Search -->
            <local:ManualAchievementsSearchControl
                DataContext="{Binding SearchVm}"
                Visibility="{Binding DataContext.IsSearchStage,
                    RelativeSource={RelativeSource AncestorType=UserControl},
                    Converter={StaticResource BooleanToVisibilityConverter}}"/>

            <!-- Stage 2: Refreshing -->
            <Grid Visibility="{Binding IsRefreshingStage,
                    RelativeSource={RelativeSource AncestorType=UserControl},
                    Converter={StaticResource BooleanToVisibilityConverter}}"
                  VerticalAlignment="Center" HorizontalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{Binding ProgressMessage}"
                           Style="{DynamicResource BaseTextBlockStyle}"
                           Foreground="{DynamicResource TextBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16"
                           TextWrapping="Wrap"
                           MaxWidth="400"/>

                <ProgressBar Grid.Row="1"
                             Value="{Binding ProgressPercent, Mode=OneWay}"
                             Maximum="100"
                             Width="350" Height="24"
                             HorizontalAlignment="Center"/>

                <TextBlock Grid.Row="2"
                           Text="{Binding ProgressPercent, StringFormat={}{0:F0}%, Mode=OneWay}"
                           Foreground="{DynamicResource TextBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"/>

                <Button Grid.Row="3"
                        Content="{DynamicResource LOCPlayAch_Button_Cancel}"
                        Command="{Binding CancelRefreshCommand}"
                        IsEnabled="{Binding CanCancelRefresh}"
                        Padding="12,6"
                        MinWidth="80"
                        HorizontalAlignment="Center"
                        Margin="0,24,0,0"/>
            </Grid>

            <!-- Stage 3: Editing -->
            <local:ManualAchievementsEditControl
                DataContext="{Binding EditVm}"
                Visibility="{Binding DataContext.IsEditingStage,
                    RelativeSource={RelativeSource AncestorType=UserControl},
                    Converter={StaticResource BooleanToVisibilityConverter}}"/>

            <!-- Error state -->
            <StackPanel Visibility="{Binding HasError,
                    RelativeSource={RelativeSource AncestorType=UserControl},
                    Converter={StaticResource BooleanToVisibilityConverter}}"
                        VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{DynamicResource TextBrush}"
                           Opacity="0.9"
                           TextWrapping="Wrap"
                           MaxWidth="400"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,24"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="{DynamicResource LOCPlayAch_Button_Retry}"
                            Command="{Binding RetryCommand}"
                            Padding="12,6"
                            MinWidth="80"
                            Margin="0,0,8,0"/>
                    <Button Content="{DynamicResource LOCPlayAch_Button_Cancel}"
                            Command="{Binding CancelCommand}"
                            Padding="12,6"
                            MinWidth="80"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Footer Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <!-- Search stage buttons -->
            <StackPanel Orientation="Horizontal"
                        Visibility="{Binding IsSearchStage,
                            RelativeSource={RelativeSource AncestorType=UserControl},
                            Converter={StaticResource BooleanToVisibilityConverter}}">
                <Button Content="{DynamicResource LOCPlayAch_Button_Next}"
                        Click="NextButton_Click"
                        Padding="12,6"
                        MinWidth="80"
                        Margin="0,0,8,0"
                        IsDefault="True"/>
                <Button Content="{DynamicResource LOCPlayAch_Button_Cancel}"
                        Click="CancelButton_Click"
                        Padding="12,6"
                        MinWidth="80"
                        IsCancel="True"/>
            </StackPanel>

            <!-- Editing stage buttons -->
            <StackPanel Orientation="Horizontal"
                        Visibility="{Binding IsEditingStage,
                            RelativeSource={RelativeSource AncestorType=UserControl},
                            Converter={StaticResource BooleanToVisibilityConverter}}">
                <Button Content="{DynamicResource LOCPlayAch_Button_Save}"
                        Click="SaveButton_Click"
                        Padding="12,6"
                        MinWidth="80"
                        Margin="0,0,8,0"
                        IsDefault="True"/>
                <Button Content="{DynamicResource LOCPlayAch_Button_Cancel}"
                        Click="CancelButton_Click"
                        Padding="12,6"
                        MinWidth="80"
                        IsCancel="True"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
