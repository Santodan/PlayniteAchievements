<settings:ProviderSettingsViewBase x:Class="PlayniteAchievements.Providers.Local.LocalSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:settings="clr-namespace:PlayniteAchievements.Providers.Settings"
             mc:Ignorable="d" d:DesignHeight="600" d:DesignWidth="700">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Providers/ProviderSettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20">
            <Border Style="{StaticResource SectionBorderStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ProviderEnabled}"
                              IsChecked="{Binding Settings.IsEnabled, Mode=TwoWay}"
                              FontWeight="SemiBold"
                              FontSize="{DynamicResource FontSize}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorderStyle}" IsEnabled="{Binding Settings.IsEnabled}">
                <StackPanel>
                    <TextBlock Text="Local Achievement Folders"
                               Style="{StaticResource SectionHeaderStyle}"
                               Margin="0,0,0,12"/>

                        <TextBlock Text="Steam path (optional):"
                               Foreground="{DynamicResource TextBrush}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,4"/>
                        <DockPanel Margin="0,0,0,6">
                        <Button Content="{DynamicResource LOCPlayAch_Button_Browse}"
                            Width="90"
                            DockPanel.Dock="Right"
                            Margin="8,0,0,0"
                            Click="SteamUserdataBrowse_Click"/>
                        <TextBox Text="{Binding Settings.SteamUserdataPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center"
                             KeyDown="SteamUserdataPath_KeyDown"
                             LostFocus="SteamUserdataPath_LostFocus"/>
                        </DockPanel>
                        <TextBlock Text="Point this to your Steam install folder or userdata folder if auto-detection misses it. Examples: E:\Programs\Steam or E:\Programs\Steam\userdata"
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,0,0,12"
                               TextWrapping="Wrap"/>

                        <TextBlock Text="The following folders are scanned automatically for local achievement and Steam cache files:"
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,0,0,10"
                               TextWrapping="Wrap"/>

                        <TextBlock Text="%SteamPath%\userdata"
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,0,0,4"/>
                        <TextBlock Text="%SteamPath%\appcache\stats"
                                   Style="{StaticResource MutedTextStyle}"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="%ProgramFiles(x86)%\Steam\userdata"
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,0,0,4"/>
                        <TextBlock Text="%ProgramFiles%\Steam\userdata"
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,0,0,4"/>
                        <TextBlock Text="&lt;Drive&gt;:\Programs\Steam, &lt;Drive&gt;:\Steam, matching userdata folders, and appcache\stats under common Steam install roots on available drives"
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,0,0,8"
                               TextWrapping="Wrap"/>

                    <TextBlock Text="%PUBLIC%\Documents\OnlineFix"
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="%PUBLIC%\Documents\Steam\RUNE"
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="%PUBLIC%\Documents\Steam\CODEX"
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="%APPDATA%\Goldberg SteamEmu Saves"
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="%APPDATA%\GSE Saves"
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="%APPDATA%\EMPRESS"
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="%PUBLIC%\EMPRESS"
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="%APPDATA%\Steam\CODEX"
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="%ProgramData%\Steam"
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="%ProgramFiles(x86)%\Steam"
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="%ProgramFiles%\Steam"
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="%LOCALAPPDATA%\SKIDROW"
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="%DOCUMENTS%\SkidRow"
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="%APPDATA%\SmartSteamEmu"
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="%APPDATA%\CreamAPI"
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,0,0,12"/>

                    <TextBlock Text="Additional folders to scan (semicolon-separated):"
                               Foreground="{DynamicResource TextBrush}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Settings.ExtraLocalPaths, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Disabled"
                             Height="100"
                             TextWrapping="Wrap"
                             Margin="0,0,0,6"/>
                    <TextBlock Text="Use semicolons (;) to separate multiple root folders. Environment variables such as %PUBLIC% or %APPDATA% are expanded automatically."
                               Style="{StaticResource MutedTextStyle}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</settings:ProviderSettingsViewBase>
